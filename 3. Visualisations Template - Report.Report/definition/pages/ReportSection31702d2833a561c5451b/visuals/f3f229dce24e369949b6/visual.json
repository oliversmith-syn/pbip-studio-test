              {
                "textRuns": [
                  {
                    "value": "Uniform alignment and distribution of visuals makes reports more professional, which aids in their credibility; it establishes a clear visual hierarchy; reduces clutter which improves readability; and makes it easier to draw comparisons across visuals.",
                    "textStyle": {
                      "color": "#767676"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": " ",
                    "textStyle": {
                      "color": "#767676"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "When aligning and distributing visuals, consider the use of white space. Try not to pack many visuals onto one page. Be consistent with the placement of objects, such as always having your filters in the same place, the refresh date in the same location etc.",
                    "textStyle": {
                      "color": "#767676"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Align and distribute visuals using the options available under the Format menu or use the position properties to remove any guess work.",
                    "textStyle": {
                      "color": "#767676"
                    }
                  }
                ]
              }
            ]
          }
