    "objects": {
      "general": [
        {
          "properties": {
            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "When building reports, be consistent with with the allocation of a colour against a category; add supplementary text for explanation; and use icons/symbols to illustrate where possible. ",
                    "textStyle": {
                      "color": "#767676"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "For example if your report has Budget and Actuals, select a colour for each and use them consistently throughout the report. ",
                    "textStyle": {
                      "color": "#767676"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Be consistent with the placement of objects, such as always having your filters in the same place, the refresh date in the same location etc. This will mean users don't have to go searching. ",
                    "textStyle": {
                      "color": "#767676"
                    }
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Implementing these design practices helps in reducing the cognitive load of users by adding visual triggers that are easily understood to assist in interpreting information.",
                    "textStyle": {
                      "color": "#767676"
                    }
                  }
                ]
              }
            ]
          }
        }
      ]
    },
