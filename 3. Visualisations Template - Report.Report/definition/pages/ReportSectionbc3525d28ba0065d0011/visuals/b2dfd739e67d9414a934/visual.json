          "properties": {
            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "When developing a report and mores specifically when you do this in Power BI, there are some some points to keep in mind and apply to make a great experience for end users.",
                    "textStyle": {
                      "fontSize": "11pt",
                      "color": "#000000"
                    }
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "A well built report will tell a story, uncover insights and assist in decision making. Following established guidelines for visual clarity will reduce end user's cognitive load, helping reports become powerful tools for understanding complex information at a glance. ",
                    "textStyle": {
                      "fontSize": "11pt",
                      "color": "#000000"
                    }
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Clear labelling, appropriate use of colour and contrast, and thoughtful layout will enhance comprehension and engagement, enabling users to grasp key findings quickly and accurately.",
                    "textStyle": {
                      "fontSize": "11pt",
                      "color": "#000000"
                    }
                  }
                ],
                "horizontalTextAlignment": "center"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Following best practice will also cultivate credibility and trust in the data.",
                    "textStyle": {
                      "fontSize": "11pt",
                      "color": "#000000"
                    }
                  }
                ],
                "horizontalTextAlignment": "center"
              }
            ]
          }
        }
      ]
