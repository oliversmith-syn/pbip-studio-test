                  },
                  {
                    "value": "climate data",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": ". From the metrics available we can then determine the conditions that highly ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": "correlate",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": " with bushfires, thus providing predictive analytics for the future incidence of bushfires.",
                    "textStyle": {
