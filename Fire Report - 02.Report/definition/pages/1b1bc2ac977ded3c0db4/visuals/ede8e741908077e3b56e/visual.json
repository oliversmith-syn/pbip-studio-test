            "paragraphs": [
              {
                "textRuns": [
                  {
                    "value": "Victoria",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": " is among the most susceptible regions in the world to ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": "bushfires",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": ". It is therefore imperative that councils are aware of the ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": "conditions",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": " that may place their jurisdiction at",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": " risk",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": ". ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  }
                ],
                "horizontalTextAlignment": "right"
              },
              {
                "textRuns": [
                  {
                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "This report will provide an overview of ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": "historical bushfires",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": " and their ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": "spatial extents",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "16pt",
                      "color": "#ffffff"
                    }
                  },
                  {
                    "value": ", before enabling the detailed inspection of Local Government Area (LGA) level ",
                    "textStyle": {
                      "fontSize": "16pt",
                      "color": "#ffffff"
