model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup 'Transform File from Sales Data'

	annotation PBI_QueryGroupOrder = 0

queryGroup 'Transform File from Sales Data\Helper Queries'

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Territory Lookup","Product Lookup","Product Category Lookup","Product Subcategory Lookup","Customer Lookup","Calendar Lookup","Product Category Sales (Unpivot Demo)","Sales Data","Parameter1","Transform Sample File","Sample File","Transform File","Returns Data","Measure Table"]

annotation PBI_ProTooling = ["DevMode"]

ref table 'Territory Lookup'
ref table 'Product Lookup'
ref table 'Product Category Lookup'
ref table 'Product Subcategory Lookup'
ref table 'Customer Lookup'
ref table 'Calendar Lookup'
ref table 'Sales Data'
ref table 'Returns Data'
ref table 'Measure Table'

ref cultureInfo en-US

